# Server
APP_ENV=development
DATABASE_URL=sqlite:///./fanvue_promotion.db
API_AUTH_SECRET=local-development-secret-change-me
ALLOW_UNSAFE_DEV_HEADERS=false
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1
AGENT_EXECUTION_ENABLED=false
FINANCIAL_ACTIONS_ENABLED=false

# LLM / open-model endpoint. Do not commit real keys.
OPEN_MODEL_BASE_URL=
OPEN_MODEL_API_KEY=
OPEN_MODEL_NAME=
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=
OMNIROUTE_TTS_URL=http://localhost:20128/v1/audio/speech
HERMES_MODEL=Nous-Hermes-3
CONTEXT_COMPRESSION_URL=
CLAUDE_CODE_BIN=claude

# Fanvue integration. Provide the official base URL from your app settings.
FANVUE_API_BASE_URL=
FANVUE_OAUTH_TOKEN_PATH=
FANVUE_MESSAGES_PATH=
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_WEBHOOK_SECRET=

# ComfyUI / diffusion gateway
COMFYUI_BASE_URL=http://127.0.0.1:8188
DEFAULT_LORA_NAME=
DEFAULT_LORA_STRENGTH=0.78
VIP_THRESHOLD_USD=50
RETENTION_WINDOW_HOURS=48
