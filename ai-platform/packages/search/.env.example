# ============================================================
# Fanvue Unified Search — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# Qwythos-9B Inference Endpoint (HF Inference Endpoint, llama.cpp container)
QWYTHOS_ENDPOINT_URL=https://your-endpoint.us-east-1.aws.endpoints.huggingface.cloud
QWYTHOS_API_KEY=hf_your_api_key_here

# Embeddings Service (TEI endpoint)
EMBEDDING_ENDPOINT_URL=https://your-tei-endpoint.us-east-1.aws.endpoints.huggingface.cloud
EMBEDDING_API_KEY=hf_your_api_key_here
EMBEDDING_DIMENSIONS=256

# Postgres (Vercel Postgres sets DATABASE_URL automatically)
DATABASE_URL=postgres://user:pass@host:5432/db

# Optional: Perplexity API for live web research
PERPLEXITY_API_KEY=pplx_your_key_here

# Search tuning
SEARCH_RESULT_LIMIT=50
SEARCH_SCORE_FLOOR=0.1
SEARCH_HYBRID_RRF_K=60
