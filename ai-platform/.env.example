# Shared production environment template.
# Copy relevant values into deployment secret manager or per-app .env files.

DATABASE_URL=postgresql+psycopg://user:password@db:5432/fanvue_platform
REDIS_URL=redis://redis:6379/0

API_BASE_URL=http://api:8000
WEB_BASE_URL=http://web:3000

APP_ENV=production
API_KEY_PEPPER=
API_AUTH_SECRET=
AUTH_MAX_AGE_SECONDS=300
ALLOW_UNSAFE_DEV_HEADERS=false
AGENT_EXECUTION_ENABLED=false
FINANCIAL_ACTIONS_ENABLED=false
ALLOWED_ORIGINS=https://your-operator-app.example
ALLOWED_HOSTS=api.example.com

FANVUE_API_BASE_URL=
FANVUE_OAUTH_TOKEN_PATH=
FANVUE_MESSAGES_PATH=
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
FANVUE_WEBHOOK_SECRET=

OPEN_MODEL_BASE_URL=
OPEN_MODEL_API_KEY=
OPEN_MODEL_NAME=
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=
OMNIROUTE_TTS_URL=http://localhost:20128/v1/audio/speech
HERMES_MODEL=Nous-Hermes-3
CONTEXT_COMPRESSION_URL=
CLAUDE_CODE_BIN=claude

COMFYUI_BASE_URL=http://comfyui:8188
DEFAULT_LORA_NAME=
DEFAULT_LORA_STRENGTH=0.78
VIP_THRESHOLD_USD=50
RETENTION_WINDOW_HOURS=48

ORNITH_BASE_URL=http://localhost:8000/v1
ORNITH_MODEL=Ornith-1.0
ORNITH_ENABLE_THINK_BLOCKS=true
USE_HF_DEDICATED=true
